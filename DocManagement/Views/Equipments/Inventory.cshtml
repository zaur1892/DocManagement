@model IEnumerable<DocManagement.Controllers.InventoryViewModel>

@{
    ViewData["Title"] = "Avadanlıqların siyahısı (İnventar)";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-box-seam me-2"></i>Avadanlıqların siyahısı (İnventar)</h2>
    <a asp-action="InventoryPdf" class="btn btn-danger">
        <i class="bi bi-file-earmark-pdf me-1"></i> PDF-ə İxrac Et
    </a>
</div>

<!-- Axtarış -->
<form method="get" asp-action="Inventory" class="mb-3">
    <div class="input-group" style="max-width: 450px;">
        <input type="text" name="search" class="form-control" 
               placeholder="Serial nömrə və ya avadanlıq adı axtar..." 
               value="@ViewBag.Search" />
        <button class="btn btn-outline-secondary" type="submit">
            <i class="bi bi-search"></i>
        </button>
        @if (!string.IsNullOrEmpty(ViewBag.Search as string))
        {
            <a asp-action="Inventory" class="btn btn-outline-danger"><i class="bi bi-x"></i> Təmizlə</a>
        }
    </div>
</form>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 50px;">#</th>
                        <th>Avadanlıq</th>
                        <th class="text-center">Ümumi Say</th>
                        <th class="text-end" style="width: 160px;">Əməliyyat</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int idx = 0;
                    }
                    @foreach (var item in Model)
                    {
                        idx++;
                        var targetId = $"details-{item.EquipmentId}-{idx}";
                        <tr>
                            <td>@idx</td>
                            <td class="fw-bold text-primary">@item.EquipmentName</td>
                            <td class="text-center">
                                <span class="badge bg-success rounded-pill px-3 py-2 fs-6">@item.Count</span>
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-secondary" type="button"
                                        data-bs-toggle="collapse" data-bs-target="#@targetId" aria-expanded="false">
                                    Detallar <i class="bi bi-chevron-down ms-1"></i>
                                </button>
                            </td>
                        </tr>

                        <!-- Collapsible Details Row -->
                        <tr class="collapse bg-light" id="@targetId">
                            <td colspan="4" class="p-0 border-bottom">
                                <div class="p-3">
                                    <h6 class="text-muted mb-3">
                                        <i class="bi bi-info-circle me-1"></i>
                                        @item.EquipmentName üçün İnventar Detalları (@item.Count ədəd)
                                    </h6>
                                    <table class="table table-sm table-bordered mb-0 bg-white">
                                        <thead class="table-secondary">
                                            <tr>
                                                <th>Serial nömrə</th>
                                                <th>Model</th>
                                                <th>Zona</th>
                                                <th>Məkan (Location)</th>
                                                <th>IP Address</th>
                                                <th>Status</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var detail in item.Details)
                                            {
                                                <tr>
                                                    <td class="fw-bold">@(string.IsNullOrEmpty(detail.SerialNumber) ? "-" : detail.SerialNumber)</td>
                                                    <td>@(string.IsNullOrEmpty(detail.Model) ? "-" : detail.Model)</td>
                                                    <td>
                                                        @if (!string.IsNullOrWhiteSpace(detail.ZoneName))
                                                        {
                                                            <span class="badge bg-primary">@detail.ZoneName</span>
                                                        }
                                                        else { <span>-</span> }
                                                    </td>
                                                    <td>@(string.IsNullOrEmpty(detail.Location) ? "-" : detail.Location)</td>
                                                    <td>
                                                        @if (!string.IsNullOrEmpty(detail.IpAddress))
                                                        {
                                                            <span class="badge bg-info text-dark">@detail.IpAddress</span>
                                                        }
                                                        else { <span>-</span> }
                                                    </td>
                                                    <td>
                                                        @if (detail.Status == "İstifadədə")
                                                        { <span class="badge bg-success">@detail.Status</span> }
                                                        else if (detail.Status == "Anbarda")
                                                        { <span class="badge bg-warning text-dark">@detail.Status</span> }
                                                        else
                                                        { <span class="badge bg-secondary">@(detail.Status ?? "-")</span> }
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </td>
                        </tr>
                    }

                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                                Heç bir inventar qeydi tapılmadı.<br />
                                <small>Tələbnamənin Tipini <strong>InventoryAction = 1 (Mədaxil)</strong> edin və sənədi <strong>Tamamlandı</strong> statusuna keçirin.</small>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
