@model IEnumerable<DocManagement.Models.Equipment>

@{
    ViewData["Title"] = "Avadanlıqlar";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Avadanlıqlar</h2>
    <a asp-action="Create" class="btn btn-primary">Yeni Avadanlıq Əlavə Et</a>
</div>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Adı</th>

            <th>Status</th>
            <th>Əməliyyatlar</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>

                <td>
                    @if (item.Status == 1)
                    {
                        <span class="badge bg-success">Aktiv</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Passiv</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Redaktə et</a>
                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Silmək istədiyinizə əminsiniz?');">
                        <button type="submit" class="btn btn-sm btn-danger">Sil</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
