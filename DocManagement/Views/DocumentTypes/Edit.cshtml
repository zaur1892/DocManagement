@model DocManagement.Models.DocumentType
@{
    ViewData["Title"] = "Tələbnamə Tipi Redaktə";
}
<form asp-controller="Settings" asp-action="EditDocumentType" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="mb-3">
        <label asp-for="Name" class="form-label fw-bold">Tip Adı</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger small"></span>
    </div>
    <button type="submit" class="btn btn-primary btn-sm">
        <i class="bi bi-check-lg me-1"></i> Yadda Saxla
    </button>
    <a asp-controller="Settings" asp-action="Index" asp-route-tab="doctypes" class="btn btn-outline-secondary btn-sm ms-2">
        <i class="bi bi-x me-1"></i> Ləğv et
    </a>
</form>
