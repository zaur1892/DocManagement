@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager
@inject SignInManager<IdentityUser> SignInManager

<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sənəd İdarəetmə</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>

    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-light border-bottom py-1">
            <div class="container-fluid">

                <a class="navbar-brand fw-bold"
                   asp-controller="Documents"
                   asp-action="Index">
                    📄 Sənədlər
                </a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse">

                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">
                            <a class="nav-link py-1 fw-bold text-primary"
                               asp-controller="Home"
                               asp-action="Index">
                                📊 Dashboard
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link py-1"
                               asp-controller="Documents"
                               asp-action="Index">
                                Ana səhifə
                            </a>
                        </li>
                        
                        <li class="nav-item">
                            <a class="nav-link py-1"
                               asp-controller="Equipments"
                               asp-action="Inventory">
                                📦 İnventar
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link py-1"
                               asp-controller="Home"
                               asp-action="Privacy">
                                Məxfilik
                            </a>
                        </li>

                    </ul>

                    <ul class="navbar-nav align-items-center">

                        <!-- SAAT + HƏFTƏNİN GÜNÜ -->
                        <li class="nav-item me-3">
                            <span id="dateTimeAz" class="nav-link py-1 fw-bold"></span>
                        </li>

                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item">
                                <span class="nav-link py-1">
                                    👤 @UserManager.GetUserName(User)
                                </span>
                            </li>

                            var user = await UserManager.GetUserAsync(User);
                            var roles = await UserManager.GetRolesAsync(user);

                            if (roles.Contains("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link py-1"
                                       asp-controller="Settings"
                                       asp-action="Index">
                                        ⚙️ Sazlamalar
                                    </a>
                                </li>
                            }

                            <li class="nav-item">
                                <form asp-controller="Account"
                                      asp-action="Logout"
                                      method="post">
                                    <button type="submit"
                                            class="btn btn-link nav-link py-1">
                                        🚪 Çıxış
                                    </button>
                                </form>
                            </li>
                        }

                    </ul>

                </div>
            </div>
        </nav>
    </header>


    <div class="container-fluid mt-2">
        <main role="main">
            @RenderBody()
        </main>
    </div>


    <footer class="border-top text-muted small text-center py-1">
        © 2025 Sənəd İdarəetmə
    </footer>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>

        function updateDateTimeAz(){

        const now = new Date();

        const days = [
        "Bazar",
        "Bazar ertəsi",
        "Çərşənbə axşamı",
        "Çərşənbə",
        "Cümə axşamı",
        "Cümə",
        "Şənbə"
        ];

        const day = now.getDate().toString().padStart(2,'0');
        const month = (now.getMonth()+1).toString().padStart(2,'0');
        const year = now.getFullYear();

        const hours = now.getHours().toString().padStart(2,'0');
        const minutes = now.getMinutes().toString().padStart(2,'0');

        const text =
        "📅 " + day + "." + month + "." + year +
        " | 🕒 " + hours + ":" + minutes +
        " | " + days[now.getDay()];

        document.getElementById("dateTimeAz").innerText = text;

        }

        updateDateTimeAz();
        setInterval(updateDateTimeAz,1000);

    </script>

    @RenderSection("Scripts", required: false)

</body>
</html>