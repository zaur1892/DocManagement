@model DocManagement.Models.Document

@{
    ViewData["Title"] = "Yeni Sənəd";
}

<h2>Yeni Sənəd</h2>

<form asp-action="Create" method="post">

    <!-- TƏLƏBNAMƏ (DOCUMENT TYPE COMBO) -->
    <div class="mb-3">
        <label class="form-label">Tələbnamə</label>
        <select asp-for="DocumentTypeId"
                asp-items="ViewBag.DocumentTypeList"
                class="form-control">
            <option value="">-- Tələbnamə seçin --</option>
        </select>
        <span asp-validation-for="DocumentTypeId" class="text-danger"></span>
    </div>

    <!-- STATUS -->
    <div class="mb-3">
        <label class="form-label">Status</label>
        <select asp-for="DocumentStatusId" class="form-control" asp-items="ViewBag.StatusList">
            <option value="">-- Status seçin --</option>
        </select>
    </div>

    <!-- ZONA -->
    <div class="mb-3">
        <label class="form-label">Zona</label>
        <select asp-for="ZoneId" class="form-control" asp-items="ViewBag.ZoneList">
            <option value="">-- Zona seçin --</option>
        </select>
    </div>

    <!-- AVADANLIQ (SELECT2 AXTARIŞLI) -->
    <div class="mb-3">
        <label class="form-label">Avadanlıq</label>
        <select asp-for="EquipmentId" asp-items="ViewBag.EquipmentList" class="select2" style="width:100%">
            <option value="">-- Avadanlıq seçin --</option>
        </select>
        <span asp-validation-for="EquipmentId" class="text-danger"></span>
    </div>

    <!-- QEYD -->
    <div class="mb-3">
        <label class="form-label">Qeyd</label>
        <textarea asp-for="Note" class="form-control"></textarea>
    </div>

    <button type="submit" class="btn btn-success">Yadda saxla</button>
    <a asp-action="Index" class="btn btn-secondary">Geri</a>
</form>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.select2').select2({
                placeholder: "-- Avadanlıq seçin --",
                allowClear: true,
                width: '100%'
            });
        });
    </script>
}
