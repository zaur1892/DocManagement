@model DocManagement.Models.Document

@{
    ViewData["Title"] = "Yeni S…ôn…ôd";
}

<h2>Yeni S…ôn…ôd</h2>

<form asp-action="Create" method="post">

    <!-- T∆ŹL∆ŹBNAM∆Ź (DOCUMENT TYPE COMBO) -->
    <div class="mb-3">
        <label class="form-label">T…ôl…ôbnam…ô Tipi</label>
        <select asp-for="DocumentTypeId"
                asp-items="ViewBag.DocumentTypeList"
                class="form-control">
            <option value="">-- T…ôl…ôbnam…ô tipi se√ßin --</option>
        </select>
        <span asp-validation-for="DocumentTypeId" class="text-danger"></span>
    </div>

    <!-- ńįNVENTAR TńįPńį -->
    <div class="mb-3">
        <label class="form-label">ńįnventar Tipi <span class="text-muted small">(AlńĪŇü, T…ômir, Yerd…ôyiŇüm…ô...)</span></label>
        <select asp-for="InventoryTypeId"
                asp-items="ViewBag.InventoryTypeList"
                class="form-control"
                id="inventoryTypeSelect"
                onchange="updateInventoryBanner()">
            <option value="">ńįnventar tipi se√ßin (ist…ôy…ô g√∂r…ô)</option>
        </select>
    </div>
    <div id="inventoryBanner" class="alert mb-2" style="display:none;"></div>

    <!-- STATUS -->
    <div class="mb-3">
        <label class="form-label">Status</label>
        <select asp-for="DocumentStatusId" class="form-control" asp-items="ViewBag.StatusList">
            <option value="">-- Status se√ßin --</option>
        </select>
    </div>

    <!-- ZONA -->
    <div class="mb-3">
        <label class="form-label">Zona</label>
        <select asp-for="ZoneId" class="form-control" asp-items="ViewBag.ZoneList">
            <option value="">-- Zona se√ßin --</option>
        </select>
    </div>

    <hr />
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h4>AvadanlńĪqlar (S…ôtrl…ôr)</h4>
        <button type="button" class="btn btn-sm btn-primary" onclick="addRow()">+ S…ôtr ∆Źlav…ô Et</button>
    </div>
    
    <div class="table-responsive">
        <table class="table table-bordered" id="itemsTable">
            <thead class="table-light">
                <tr>
                    <th>AvadanlńĪq N√∂v√ľ <span class="text-danger">*</span></th>
                    <th>Seriya N√∂mr…ôsi</th>
                    <th>Model</th>
                    <th>Lokasiya</th>
                    <th>IP √únvan</th>
                    <th style="width:70px;">Say</th>
                    <th>ńįnventar</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="itemsBody">
                <!-- Javascript will insert rows here -->
            </tbody>
        </table>
    </div>
    
    <!-- Gizli Ňüablon Dropdown √ľ√ß√ľn -->
    <div style="display:none" id="equipmentTemplate">
        <select class="form-control select2-template" name="Items[#INDEX#].EquipmentId" disabled required>
            <option value="">-- Se√ßin --</option>
            @foreach(var item in ViewBag.EquipmentList as SelectList)
            {
                <option value="@item.Value">@item.Text</option>
            }
        </select>
    </div>

    <!-- QEYD -->
    <div class="mb-3">
        <label class="form-label">Qeyd</label>
        <textarea asp-for="Note" class="form-control"></textarea>
    </div>

    <button type="submit" class="btn btn-success">Yadda saxla</button>
    <a asp-action="Index" class="btn btn-secondary">Geri</a>
</form>

@section Scripts {
    <script>
        let rowIndex = 0;

        function addRow() {
            // Remove the 'disabled' attribute when using the template
            let selectHtml = $('#equipmentTemplate').html().replace(/#INDEX#/g, rowIndex).replace('disabled', '');
            
            let rowHtml = `
                <tr id="row_${rowIndex}">
                    <td>${selectHtml}</td>
                    <td>
                        <div class="input-group">
                            <input type="text"
                                   name="Items[${rowIndex}].SerialNumber"
                                   class="form-control serial-input"
                                   placeholder="Seriya n√∂mr…ôsi"
                                   data-row="${rowIndex}"
                                   autocomplete="off" />
                        </div>
                    </td>
                    <td><input type="text" name="Items[${rowIndex}].Model" class="form-control" placeholder="Model" /></td>
                    <td><input type="text" name="Items[${rowIndex}].Location" class="form-control" placeholder="Otaq/Zona" /></td>
                    <td><input type="text" name="Items[${rowIndex}].IpAddress" class="form-control" placeholder="192.168..." /></td>
                    <td><input type="number" name="Items[${rowIndex}].Qty" class="form-control text-center" value="1" min="1" style="width:60px;" /></td>
                    <td id="inv-status-${rowIndex}" style="min-width:80px;vertical-align:middle"></td>
                    <td>
                        <button type="button" class="btn btn-sm btn-danger" onclick="removeRow(${rowIndex})">X</button>
                    </td>
                </tr>
            `;
            
            $('#itemsBody').append(rowHtml);
            
            // Re-initialize select2 for the new row if needed
            $(`#row_${rowIndex} select`).select2({
                placeholder: "-- Se√ßin --",
                allowClear: true,
                width: '100%'
            });

            // Serial input √ľ√ß√ľn lookup hadis…ôsi
            bindSerialLookup(rowIndex);

            rowIndex++;
        }

        function removeRow(index) {
            $(`#row_${index}`).remove();
        }

        // Seriya n√∂mr…ôsin…ô g√∂r…ô inventardan m…ôlumat g…ôtir
        let serialTimers = {};
        function bindSerialLookup(idx) {
            $(`#row_${idx} .serial-input`).on('input', function() {
                const serial = $(this).val().trim();
                const row = $(`#row_${idx}`);
                const statusCell = $(`#inv-status-${idx}`);

                clearTimeout(serialTimers[idx]);

                if (!serial) {
                    statusCell.html('');
                    return;
                }

                statusCell.html('<span class="text-muted"><small>ūüĒć...</small></span>');

                serialTimers[idx] = setTimeout(function() {
                    $.getJSON('/Equipments/LookupBySerial', { serial: serial }, function(data) {
                        if (data) {
                            // M…ôlumatlarńĪ doldur
                            if (data.model)     row.find('[name$=".Model"]').val(data.model);
                            if (data.location)  row.find('[name$=".Location"]').val(data.location);
                            if (data.ipAddress) row.find('[name$=".IpAddress"]').val(data.ipAddress);
                            // AvadanlńĪq n√∂v√ľn√ľ se√ß
                            if (data.equipmentId) {
                                row.find('select').val(data.equipmentId).trigger('change');
                            }
                            statusCell.html('<span class="badge bg-success" title="ńįnventarda m√∂vcuddur">‚úď ńįnventarda</span>');
                        } else {
                            statusCell.html('<span class="badge bg-warning text-dark" title="ńįnventarda yoxdur ‚ÄĒ yeni …ôlav…ô">Yeni</span>');
                        }
                    }).fail(function() {
                        statusCell.html('');
                    });
                }, 500);
            });
        }

        $(document).ready(function () {
            // S…ôhif…ô a√ßńĪlanda avtomatik 1 s…ôtr …ôlav…ô et
            addRow();
            updateInventoryBanner();
        });

        // ńįnventar Tipi d…ôyiŇüdikd…ô canlńĪ banner g√∂st…ôr
        function updateInventoryBanner() {
            const sel = document.getElementById('inventoryTypeSelect');
            const banner = document.getElementById('inventoryBanner');
            if (!sel || !banner) return;

            const selectedOption = sel.options[sel.selectedIndex];
            const val = sel.value;

            if (!val) {
                banner.style.display = 'none';
                return;
            }

            $.getJSON('/Settings/GetInventoryTypeAction', { id: val }, function(data) {
                banner.style.display = 'block';
                if (data.action === 0) {
                    banner.className = 'alert alert-secondary mb-2';
                    banner.innerHTML = '‚ö†ÔłŹ <strong>' + selectedOption.text + '</strong> se√ßildi. Bu tip inventara <strong>t…ôsir etmir</strong>.';
                } else if (data.action === 1) {
                    banner.className = 'alert alert-success mb-2';
                    banner.innerHTML = '‚úÖ <strong>' + selectedOption.text + '</strong> ‚ÄĒ AvadanlńĪq inventara <strong>m…ôdaxil</strong> olunacaq.';
                } else if (data.action === 2) {
                    banner.className = 'alert alert-info mb-2';
                    banner.innerHTML = 'ūüď¶ <strong>' + selectedOption.text + '</strong> ‚ÄĒ M√∂vcud inventar qeydinin <strong>yerd…ôyiŇüm…ôsi</strong> qeyd edil…ôc…ôk.';
                }
            });
        }
        
        // Enter d√ľym…ôsini basanda formun yadda saxlanmasńĪnńĪn qarŇüńĪsńĪnńĪ al
        $(document).on('keypress', 'input,select', function (e) {
            if (e.which == 13) {
                e.preventDefault();
                return false;
            }
        });
    </script>
}
