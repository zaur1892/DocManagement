@model IEnumerable<DocManagement.Models.DocumentListView>
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@using System.Globalization

@{
    ViewData["Title"] = "Sənədlər";

    var currentAction = HttpContextAccessor.HttpContext.Request.RouteValues["action"]?.ToString();

    var startDateVal = string.IsNullOrEmpty(ViewBag.StartDate as string) && currentAction == "Index"
        ? DateTime.Now.AddMonths(-1).ToString("yyyy-MM-dd")
        : ViewBag.StartDate;

    var endDateVal = string.IsNullOrEmpty(ViewBag.EndDate as string) && currentAction == "Index"
        ? DateTime.Now.ToString("yyyy-MM-dd")
        : ViewBag.EndDate;

    var user = HttpContextAccessor.HttpContext.User;
    var isAdmin = user.IsInRole("Admin");

    var columns = ViewBag.Columns as List<DocManagement.Models.DocElement>;
}

<h1>Tələbnamələr</h1>

<div style="text-align:right; font-weight:bold; margin-bottom:10px;">
    <div id="dateTimeAz"></div>
    <div id="weekDayAz" style="font-size:14px;"></div>
</div>

<p>
    <a class="btn btn-primary" asp-action="Create">Yeni Tələbnamə</a>
</p>

<form method="get" asp-action="Index" class="row g-3 mb-3">

    <div class="col-md-3 col-sm-6">
        <label class="form-label">Tələbnamə Tipi</label>
        <select name="documentTypeId" class="form-control" asp-items="ViewBag.DocumentTypeList">
            <option value="">-- Hamısı --</option>
        </select>
    </div>

    <div class="col-md-3 col-sm-6">
        <label class="form-label">Status</label>
        <select name="statusId" class="form-control" asp-items="ViewBag.StatusList">
            <option value="">-- Hamısı --</option>
        </select>
    </div>

    <div class="col-md-2 col-sm-6">
        <label class="form-label">Başlanğıc Tarix</label>
        <input type="date" name="startDate" class="form-control" value="@startDateVal" />
    </div>

    <div class="col-md-2 col-sm-6">
        <label class="form-label">Son Tarix</label>
        <input type="date" name="endDate" class="form-control" value="@endDateVal" />
    </div>

    <div class="col-md-2 col-sm-6 align-self-end">
        <button type="submit" class="btn btn-outline-primary w-100">Axtar</button>
    </div>

    <div class="col-md-3 col-sm-6 align-self-end">
        <a id="indexLink" asp-action="Index" class="btn btn-secondary w-100">Hamısını Göstər</a>
    </div>

    <div class="col-md-3 col-sm-6 align-self-end">
        <a id="teleblerimLink" asp-action="Teleblerim" class="btn btn-outline-primary w-100">Tələblərim</a>
    </div>

    <div class="col-md-3 col-sm-6 align-self-end">
        <a id="tamamlananlarLink" asp-action="Tamamlananlar" class="btn btn-outline-success w-100">Tamamlananlar</a>
    </div>

    <div class="col-md-3 col-sm-6 align-self-end">
        <a id="excelLink" asp-action="ExportToExcel" class="btn btn-success w-100">Excelə Yüklə</a>
    </div>

</form>


<div class="table-responsive">
    <table class="table table-striped table-bordered align-middle">

        <thead class="table-light">
            <tr>


                @foreach (var col in columns)
                {
                    <th>@col.DisplayName</th>
                }

                <th>Əməliyyatlar</th>

            </tr>
        </thead>

        <tbody>

            @foreach (var d in Model)
            {
                <tr>

                  

                    @foreach (var col in columns)
                    {
                        <td>

                            @if (col.ColumnName == "DocumentTypeName")
                            {
                                @d.DocumentTypeName
                            }

                            else if (col.ColumnName == "Id")
                            {
                                @d.Id
                            }


                            else if (col.ColumnName == "CreatedAt")
                            {
                                @d.CreatedAt.ToString("dd.MM.yyyy", CultureInfo.GetCultureInfo("az-AZ"))
                            }
                            else if (col.ColumnName == "StatusName")
                            {
                                <span class="badge" style="background:@d.StatusColor;color:white">
                                    @d.StatusName
                                </span>
                            }
                            else if (col.ColumnName == "ZoneName")
                            {
                                @(d.ZoneName ?? "-")
                            }
                            else if (col.ColumnName == "EquipmentName")
                            {
                                @(d.EquipmentName ?? "-")
                            }
                            else if (col.ColumnName == "Note")
                            {
                                @(string.IsNullOrWhiteSpace(d.Note) ? "-" : d.Note)
                            }
                            else if (col.ColumnName == "CustomFieldName1")
                            {
                                @(string.IsNullOrWhiteSpace(d.CustomFieldName1) ? "-" : d.CustomFieldName1)
                            }
                            else if (col.ColumnName == "CustomFieldName2")
                            {
                                @(string.IsNullOrWhiteSpace(d.CustomFieldName2) ? "-" : d.CustomFieldName2)
                            }
                            else if (col.ColumnName == "CustomFieldName3")
                            {
                                @(string.IsNullOrWhiteSpace(d.CustomFieldName3) ? "-" : d.CustomFieldName3)
                            }

                        </td>
                    }

                    <td>

                        @if (isAdmin)
                        {
                            <a asp-action="Edit" asp-route-id="@d.Id" class="btn btn-sm btn-info">Redaktə</a>
                            <a asp-action="Delete" asp-route-id="@d.Id" class="btn btn-sm btn-danger">Sil</a>
                        }

                        <a asp-action="Details" asp-route-id="@d.Id" class="btn btn-sm btn-secondary">Detal</a>

                    </td>

                </tr>
            }

        </tbody>
    </table>
</div>


<script>

    function updateDateTimeAz(){
    const now = new Date();

    const days = [
    "Bazar",
    "Bazar ertəsi",
    "Çərşənbə axşamı",
    "Çərşənbə",
    "Cümə axşamı",
    "Cümə",
    "Şənbə"
    ];

    document.getElementById("dateTimeAz").innerText = now.toLocaleString("az-AZ");
    document.getElementById("weekDayAz").innerText = days[now.getDay()];
    }

    updateDateTimeAz();
    setInterval(updateDateTimeAz,1000);


    function setLinkQuery(linkId){

    const link = document.getElementById(linkId);

    link.addEventListener('click',function(e){

    e.preventDefault();

    const start = document.querySelector('input[name="startDate"]').value;
    const end = document.querySelector('input[name="endDate"]').value;

    const url = new URL(link.href,window.location.origin);

    if(start) url.searchParams.set("startDate",start);
    if(end) url.searchParams.set("endDate",end);

    const docType = document.querySelector('select[name="documentTypeId"]').value;
    const status = document.querySelector('select[name="statusId"]').value;

    if(docType) url.searchParams.set("documentTypeId",docType);
    if(status) url.searchParams.set("statusId",status);

    window.location.href = url;

    });

    }

    setLinkQuery("teleblerimLink");
    setLinkQuery("tamamlananlarLink");
    setLinkQuery("excelLink");

</script>