@model Document
<h2>Düzəliş et</h2>
<form asp-action="Edit">
    <input type="hidden" asp-for="Id" />
    <div class="form-group">
        <label asp-for="Title"></label>
        <input asp-for="Title" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="TrainArrivalTime" class="control-label"></label>
        <input asp-for="TrainArrivalTime" class="form-control" type="datetime-local" />
        <span asp-validation-for="TrainArrivalTime" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="DocumentNumber"></label>
        <input asp-for="DocumentNumber" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Yadda saxla</button>
    <a asp-action="Index" class="btn btn-secondary">Geri</a>
</form>
