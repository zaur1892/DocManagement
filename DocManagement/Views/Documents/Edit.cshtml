@model DocManagement.Models.Document

<h2>Sənədi Düzəliş Et</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <!-- TƏLƏBNAMƏ (DOCUMENT TYPE COMBO) -->
    <div class="mb-3">
        <label class="form-label">Tələbnamə Tipi</label>
        <select asp-for="DocumentTypeId"
                asp-items="ViewBag.DocumentTypeList"
                class="form-control">
            <option value="">-- Tələbnamə tipi seçin --</option>
        </select>
        <span asp-validation-for="DocumentTypeId" class="text-danger"></span>
    </div>

    <!-- İNVENTAR TİPİ -->
    <div class="mb-3">
        <label class="form-label">İnventar Tipi <span class="text-muted small">(Alış, Təmir, Yerdəyişmə...)</span></label>
        <select asp-for="InventoryTypeId"
                asp-items="ViewBag.InventoryTypeList"
                class="form-control">
            <option value="">İnventar tipi seçin (istəyə görə)</option>
        </select>
    </div>

    <!-- STATUS -->
    <div class="form-group">
        <label>Status</label>
        <select asp-for="DocumentStatusId" class="form-control" asp-items="ViewBag.StatusList">
            <option value="">-- Status seçin --</option>
        </select>
        <span asp-validation-for="DocumentStatusId" class="text-danger"></span>
    </div>

    <!-- ZONA -->
    <div class="mb-3">
        <label class="form-label">Zona</label>
        <select asp-for="ZoneId" class="form-control" asp-items="ViewBag.ZoneList">
            <option value="">-- Zona seçin --</option>
        </select>
        <span asp-validation-for="ZoneId" class="text-danger"></span>
    </div>

    <hr />
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h4>Avadanlıqlar (Sətrlər)</h4>
        <button type="button" class="btn btn-sm btn-primary" onclick="addRow()">+ Sətr Əlavə Et</button>
    </div>
    
    <div class="table-responsive">
        <table class="table table-bordered" id="itemsTable">
            <thead class="table-light">
                <tr>
                    <th>Avadanlıq Növü <span class="text-danger">*</span></th>
                    <th>Seriya Nömrəsi</th>
                    <th>Model</th>
                    <th>Lokasiya</th>
                    <th>IP Ünvan</th>
                    <th>İnventar</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="itemsBody">
                @if(Model.Items != null && Model.Items.Any())
                {
                    int idx = 0;
                    foreach(var item in Model.Items)
                    {
                        <tr id="row_@idx">
                            <td>
                                <select class="form-control select2" name="Items[@idx].EquipmentId" required>
                                    <option value="">-- Seçin --</option>
                                    @foreach(var eq in ViewBag.EquipmentList as SelectList)
                                    {
                                        if (eq.Value == item.EquipmentId.ToString())
                                        {
                                            <option value="@eq.Value" selected>@eq.Text</option>
                                        }
                                        else
                                        {
                                            <option value="@eq.Value">@eq.Text</option>
                                        }
                                    }
                                </select>
                            </td>
                            <td><input type="text" name="Items[@idx].SerialNumber" value="@item.SerialNumber" class="form-control serial-input" data-row="@idx" autocomplete="off" /></td>
                            <td><input type="text" name="Items[@idx].Model" value="@item.Model" class="form-control" /></td>
                            <td><input type="text" name="Items[@idx].Location" value="@item.Location" class="form-control" /></td>
                            <td><input type="text" name="Items[@idx].IpAddress" value="@item.IpAddress" class="form-control" /></td>
                            <td id="inv-status-@idx" style="min-width:80px;vertical-align:middle">
                                @if (!string.IsNullOrWhiteSpace(item.SerialNumber))
                                {
                                    <span class="badge bg-success" title="Mövcuddur">✓</span>
                                }
                            </td>
                            <td>
                                <button type="button" class="btn btn-sm btn-danger" onclick="removeRow(@idx)">X</button>
                                <input type="hidden" name="Items[@idx].Id" value="@item.Id" />
                                <input type="hidden" name="Items[@idx].DocumentId" value="@item.DocumentId" />
                            </td>
                        </tr>
                        idx++;
                    }
                }
            </tbody>
        </table>
    </div>
    
    <!-- Gizli şablon Dropdown üçün -->
    <div style="display:none" id="equipmentTemplate">
        <select class="form-control select2-template" name="Items[#INDEX#].EquipmentId" disabled required>
            <option value="">-- Seçin --</option>
            @foreach(var item in ViewBag.EquipmentList as SelectList)
            {
                <option value="@item.Value">@item.Text</option>
            }
        </select>
    </div>

    <!-- QEYD -->
    <div class="form-group">
        <label>Qeyd</label>
        <textarea asp-for="Note" class="form-control"></textarea>
        <span asp-validation-for="Note" class="text-danger"></span>
    </div>

    <br />
    <button type="submit" class="btn btn-primary">Yadda saxla</button>
    <a asp-action="Index" class="btn btn-secondary">Geri</a>
</form>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        let rowIndex = @(Model.Items?.Count ?? 0);

        function addRow() {
            let selectHtml = $('#equipmentTemplate').html().replace(/#INDEX#/g, rowIndex).replace('disabled', '');
            
            let rowHtml = `
                <tr id="row_${rowIndex}">
                    <td>${selectHtml}</td>
                    <td>
                        <div class="input-group">
                            <input type="text"
                                   name="Items[${rowIndex}].SerialNumber"
                                   class="form-control serial-input"
                                   placeholder="Seriya nömrəsi"
                                   data-row="${rowIndex}"
                                   autocomplete="off" />
                        </div>
                    </td>
                    <td><input type="text" name="Items[${rowIndex}].Model" class="form-control" placeholder="Model" /></td>
                    <td><input type="text" name="Items[${rowIndex}].Location" class="form-control" placeholder="Otaq/Zona" /></td>
                    <td><input type="text" name="Items[${rowIndex}].IpAddress" class="form-control" placeholder="192.168..." /></td>
                    <td id="inv-status-${rowIndex}" style="min-width:80px;vertical-align:middle"></td>
                    <td>
                        <button type="button" class="btn btn-sm btn-danger" onclick="removeRow(${rowIndex})">X</button>
                    </td>
                </tr>
            `;
            
            $('#itemsBody').append(rowHtml);
            
            $(`#row_${rowIndex} select`).select2({
                placeholder: "-- Seçin --",
                allowClear: true,
                width: '100%'
            });

            bindSerialLookup(rowIndex);
            rowIndex++;
        }

        function removeRow(index) {
            $(`#row_${index}`).remove();
        }

        // Seriya nömrəsinə görə inventardan məlumat gətir
        let serialTimers = {};
        function bindSerialLookup(idx) {
            $(`#row_${idx} .serial-input`).on('input', function() {
                const serial = $(this).val().trim();
                const row = $(`#row_${idx}`);
                const statusCell = $(`#inv-status-${idx}`);

                clearTimeout(serialTimers[idx]);

                if (!serial) { statusCell.html(''); return; }

                statusCell.html('<span class="text-muted"><small>🔍...</small></span>');

                serialTimers[idx] = setTimeout(function() {
                    $.getJSON('/Equipments/LookupBySerial', { serial: serial }, function(data) {
                        if (data) {
                            if (data.model)     row.find('[name$=".Model"]').val(data.model);
                            if (data.location)  row.find('[name$=".Location"]').val(data.location);
                            if (data.ipAddress) row.find('[name$=".IpAddress"]').val(data.ipAddress);
                            if (data.equipmentId) row.find('select').val(data.equipmentId).trigger('change');
                            statusCell.html('<span class="badge bg-success">✓ İnventarda</span>');
                        } else {
                            statusCell.html('<span class="badge bg-warning text-dark">Yeni</span>');
                        }
                    }).fail(function() { statusCell.html(''); });
                }, 500);
            });
        }

        $(document).ready(function () {
            $('.select2').select2({
                placeholder: "-- Seçin --",
                allowClear: true,
                width: '100%'
            });
            
            if (rowIndex === 0) {
                addRow();
            }
        });
        
        // Enter düyməsini basanda formun yadda saxlanmasının qarşısını al
        $(document).on('keypress', 'input,select', function (e) {
            if (e.which == 13) {
                e.preventDefault();
                return false;
            }
        });
    </script>
}
