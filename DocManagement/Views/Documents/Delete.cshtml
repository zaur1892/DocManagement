@model DocManagement.Models.Document

<h2>Əminsiniz?</h2>

<div class="alert alert-warning">
    <strong>@Model.DocumentType</strong> — @Model.DocumentType sənədini silmək istədiyinizə əminsiniz?
</div>

<p>
    Bu sənəd <strong>passiv ediləcək</strong> (status = 0).
</p>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">
        Sil
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Geri
    </a>
</form>
