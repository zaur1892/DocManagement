@model DocManagement.Models.Zone
@{ ViewData["Title"] = "Yeni Zona"; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <h5><i class="bi bi-plus-circle me-2"></i>Yeni Zona</h5>
    <a asp-controller="Settings" asp-action="Index" asp-route-tab="zones" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i> Geri</a>
</div>
<div class="card shadow-sm" style="max-width:400px">
    <div class="card-body">
        <form asp-controller="Settings" asp-action="CreateZone" method="post">
            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-bold">Zona Adı</label>
                <input asp-for="Name" class="form-control" placeholder="Məs: Anbar, Ofis, Servis..." />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i> Əlavə Et</button>
        </form>
    </div>
</div>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
