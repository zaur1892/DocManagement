@model EvtapAz.Models.RegisterViewModel
@{
    ViewData["Title"] = "Qeydiyyat";
    Layout = null;
}
<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width,initial-scale=1"/>
    <title>Qeydiyyat — evtap.az</title>
    <link rel="stylesheet" href="~/css/site.css"/>
</head>
<body>
<div class="auth-container">
    <div class="auth-card">
        <div class="auth-logo">
            <h1>evtap<span>.az</span></h1>
            <p>Pulsuz hesab açın</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                @Html.ValidationSummary(false)
            </div>
        }

        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()

            <div class="form-grid-2" style="margin-bottom:1rem">
                <div class="form-group">
                    <label class="form-label">Ad Soyad</label>
                    <input asp-for="FullName" class="form-control" placeholder="Ad Soyad"/>
                    <span asp-validation-for="FullName" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label">İstifadəçi adı</label>
                    <input asp-for="UserName" class="form-control" placeholder="username"/>
                    <span asp-validation-for="UserName" class="field-validation-error"></span>
                </div>
            </div>

            <div class="form-group" style="margin-bottom:1rem">
                <label class="form-label">Email</label>
                <input asp-for="Email" class="form-control" placeholder="email@example.com" type="email"/>
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>

            <div class="form-group" style="margin-bottom:1rem">
                <label class="form-label">Telefon</label>
                <input asp-for="Phone" class="form-control" placeholder="+994 50 XXX XX XX"/>
                <span asp-validation-for="Phone" class="field-validation-error"></span>
            </div>

            <div class="form-grid-2" style="margin-bottom:1.5rem">
                <div class="form-group">
                    <label class="form-label">Şifrə</label>
                    <input asp-for="Password" class="form-control" placeholder="••••••" type="password"/>
                    <span asp-validation-for="Password" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label">Şifrə təkrar</label>
                    <input asp-for="ConfirmPassword" class="form-control" placeholder="••••••" type="password"/>
                    <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
                </div>
            </div>

            <button type="submit" class="btn btn-accent" style="width:100%">Qeydiyyatdan keç →</button>
        </form>

        <div class="auth-footer">
            Artıq hesabınız var? <a asp-action="Login">Daxil olun</a>
        </div>
        <div class="auth-footer" style="margin-top:0.5rem">
            <a asp-controller="Home" asp-action="Index">← Ana Səhifəyə Qayıt</a>
        </div>
    </div>
</div>
</body>
</html>
